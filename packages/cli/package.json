{
  "name": "@knowledge-compiler/cli",
  "version": "0.1.0",
  "description": "Knowledge Compiler command-line interface",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kc": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bin": {
      "import": "./dist/bin.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@knowledge-compiler/core": "workspace:*",
    "@knowledge-compiler/config": "workspace:*",
    "@knowledge-compiler/artifacts": "workspace:*",
    "cac": "^6.7.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "cli-progress": "^3.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
